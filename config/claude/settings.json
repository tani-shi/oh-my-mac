{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude is waiting for your input\" with title \"Claude Code\" sound name \"Funk\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [[ -x ~/.claude/scripts/check-docs.zsh ]]; then zsh ~/.claude/scripts/check-docs.zsh; fi && osascript -e 'display notification \"Task completed\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-sentinel"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "teammateMode": "auto",
  "permissions": {
    "defaultMode": "default",
    "deny": [],
    "allow": [
      "Edit",
      "Glob",
      "Grep",
      "MultiEdit",
      "Read",
      "Search",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Write",
      "mcp__claude_ai_Slack__slack_read_*",
      "mcp__claude_ai_Slack__slack_search_*",
      "mcp__plugin_context7_context7__*"
    ],
    "ask": [
      "mcp__claude_ai_Slack__slack_create_canvas",
      "mcp__claude_ai_Slack__slack_schedule_message",
      "mcp__claude_ai_Slack__slack_send_message",
      "mcp__claude_ai_Slack__slack_send_message_draft",
      "mcp__claude_ai_Slack__slack_update_canvas"
    ]
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "tani-shi-skills": {
      "source": {
        "source": "git",
        "url": "git@github.com:tani-shi/skills.git"
      }
    }
  }
}
