{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "zsh ~/.claude/scripts/claude-hook.zsh notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "zsh ~/.claude/scripts/claude-hook.zsh stop"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "zsh ~/.claude/scripts/claude-hook.zsh userpromptsubmit"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "zsh ~/.claude/scripts/claude-hook.zsh taskcompleted"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "zsh ~/.claude/scripts/claude-sentinel-wrapper.zsh"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "medium",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "teammateMode": "tmux",
  "tui": "fullscreen",
  "permissions": {
    "allow": [
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "Search",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Write",
      "mcp__claude_ai_Slack__slack_read_*",
      "mcp__claude_ai_Slack__slack_search_*",
      "mcp__plugin_context7_context7__*"
    ],
    "deny": [
      "Edit(**/*.jks)",
      "Edit(**/*.key)",
      "Edit(**/*.keystore)",
      "Edit(**/*.p12)",
      "Edit(**/*.pem)",
      "Edit(**/*.pfx)",
      "Edit(**/.aws/**)",
      "Edit(**/.azure/**)",
      "Edit(**/.boto)",
      "Edit(**/.config/gcloud/**)",
      "Edit(**/.config/gh/hosts.yml)",
      "Edit(**/.docker/config.json)",
      "Edit(**/.env)",
      "Edit(**/.envrc)",
      "Edit(**/.gnupg/**)",
      "Edit(**/.gradle/gradle.properties)",
      "Edit(**/.htpasswd)",
      "Edit(**/.kube/config)",
      "Edit(**/.m2/settings.xml)",
      "Edit(**/.my.cnf)",
      "Edit(**/.netrc)",
      "Edit(**/.npmrc)",
      "Edit(**/.pgpass)",
      "Edit(**/.pypirc)",
      "Edit(**/.s3cfg)",
      "Edit(**/.ssh/**)",
      "Edit(**/.terraformrc)",
      "Edit(**/.vault-token)",
      "Edit(**/client_secret.json)",
      "Edit(**/credentials.json)",
      "Edit(**/secrets.json)",
      "Edit(**/secrets.toml)",
      "Edit(**/secrets.yaml)",
      "Edit(**/secrets.yml)",
      "Edit(**/service-account*.json)",
      "Edit(**/service_account*.json)",
      "Edit(**/terraform.tfvars)",
      "Edit(**/terraform.tfvars.json)",
      "Read(**/*.jks)",
      "Read(**/*.key)",
      "Read(**/*.keystore)",
      "Read(**/*.p12)",
      "Read(**/*.pem)",
      "Read(**/*.pfx)",
      "Read(**/.aws/**)",
      "Read(**/.azure/**)",
      "Read(**/.boto)",
      "Read(**/.config/gcloud/**)",
      "Read(**/.config/gh/hosts.yml)",
      "Read(**/.docker/config.json)",
      "Read(**/.env)",
      "Read(**/.envrc)",
      "Read(**/.gnupg/**)",
      "Read(**/.gradle/gradle.properties)",
      "Read(**/.htpasswd)",
      "Read(**/.kube/config)",
      "Read(**/.m2/settings.xml)",
      "Read(**/.my.cnf)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pgpass)",
      "Read(**/.pypirc)",
      "Read(**/.s3cfg)",
      "Read(**/.ssh/**)",
      "Read(**/.terraformrc)",
      "Read(**/.vault-token)",
      "Read(**/client_secret.json)",
      "Read(**/credentials.json)",
      "Read(**/secrets.json)",
      "Read(**/secrets.toml)",
      "Read(**/secrets.yaml)",
      "Read(**/secrets.yml)",
      "Read(**/service-account*.json)",
      "Read(**/service_account*.json)",
      "Read(**/terraform.tfvars)",
      "Read(**/terraform.tfvars.json)"
    ],
    "ask": [
      "mcp__claude_ai_Slack__slack_create_canvas",
      "mcp__claude_ai_Slack__slack_schedule_message",
      "mcp__claude_ai_Slack__slack_send_message",
      "mcp__claude_ai_Slack__slack_send_message_draft",
      "mcp__claude_ai_Slack__slack_update_canvas"
    ],
    "defaultMode": "default",
    "disableAutoMode": "disable"
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  }
}
