{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude is waiting for your input\" with title \"Claude Code\" sound name \"Funk\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task completed\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-sentinel"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/secrets.yml)",
      "Read(**/secrets.yaml)",
      "Read(**/secrets.json)",
      "Read(**/secrets.toml)",
      "Read(**/terraform.tfvars)",
      "Read(**/terraform.tfvars.json)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.azure/**)",
      "Read(**/credentials.json)",
      "Read(**/client_secret*.json)",
      "Read(**/service_account*.json)",
      "Read(**/service-account*.json)",
      "Read(~/.terraformrc)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/config)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.m2/settings.xml)",
      "Read(~/.gradle/gradle.properties)",
      "Read(~/.boto)",
      "Read(~/.s3cfg)",
      "Read(~/.pgpass)",
      "Read(~/.my.cnf)",
      "Read(~/.htpasswd)",
      "Read(~/.vault-token)"
    ],
    "allow": [
      "Glob",
      "Grep",
      "Search",
      "Skill",
      "WebFetch",
      "WebSearch",
      "mcp__claude_ai_Slack__slack_read_*",
      "mcp__claude_ai_Slack__slack_search_*"
    ],
    "ask": [
      "mcp__claude_ai_Slack__slack_create_canvas",
      "mcp__claude_ai_Slack__slack_schedule_message",
      "mcp__claude_ai_Slack__slack_send_message",
      "mcp__claude_ai_Slack__slack_send_message_draft",
      "mcp__claude_ai_Slack__slack_update_canvas"
    ]
  },
  "extraKnownMarketplaces": {
    "tani-shi-skills": {
      "source": {
        "source": "git",
        "url": "git@github.com:tani-shi/skills.git"
      }
    }
  }
}
