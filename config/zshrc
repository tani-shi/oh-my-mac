# Homebrew
eval "$(/opt/homebrew/bin/brew shellenv)"

# History
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY

# Sheldon (plugin manager)
eval "$(sheldon source)"

# fnm (Node.js version manager)
eval "$(fnm env --use-on-cd --shell zsh)"

# uv (Python)
export PATH="$HOME/.local/bin:$PATH"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
export PATH="$PNPM_HOME:$PATH"

# Warn and block pip in favor of uv
pip() {
  echo "⚠ Use uv instead of pip"
  echo "  pip install <pkg>  → uv add <pkg>"
  echo "  pip install -g     → uv tool install <pkg>"
  echo "  pip install -r     → uv pip install -r requirements.txt"
  return 1
}

pip3() {
  echo "⚠ Use uv instead of pip3"
  echo "  pip3 install <pkg> → uv add <pkg>"
  return 1
}

alias python="$(uv python find)"
alias python3="$(uv python find)"

ipinfo() {
  if [[ -z "$1" ]]; then
    curl -s "https://ipinfo.io"
  else
    curl -s "https://ipinfo.io/$1"
  fi
}

# bat
export BAT_THEME="TwoDark"
alias cat="bat"

# eza
ls() { eza --icons "$@" }
ll() { eza --icons -la "$@" }
lt() { eza --icons --tree "$@" }
compdef ls=eza ll=eza lt=eza

# fd + fzf
export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type d --hidden --follow --exclude .git"

# btop
alias top="btop"

# zoxide (smarter cd)
eval "$(zoxide init zsh)"

# Prevent Claude Code from overriding the terminal title
export CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1

# iTerm2 tab title: show current directory basename
_iterm2_tab_title() { print -Pn "\e]1;%1~\a" }
# iTerm2 tab color: reset on each shell command (clears Claude Code state colors)
_iterm2_tab_color_reset() { print -Pn "\e]6;1;bg;*;default\a" }
precmd_functions+=(_iterm2_tab_title)
preexec_functions+=(_iterm2_tab_title _iterm2_tab_color_reset)

# Starship (must be last)
export STARSHIP_LOG=error
eval "$(starship init zsh)"
