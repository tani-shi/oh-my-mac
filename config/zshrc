# Homebrew
eval "$(/opt/homebrew/bin/brew shellenv)"

# Completion
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select

# History
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY

# Sheldon (plugin manager)
eval "$(sheldon source)"

# fnm (Node.js version manager)
eval "$(fnm env --use-on-cd --shell zsh)"

# uv (Python)
export PATH="$HOME/.local/bin:$PATH"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
export PATH="$PNPM_HOME:$PATH"

# Warn and block pip in favor of uv
pip() {
  echo "⚠ Use uv instead of pip"
  echo "  pip install <pkg>  → uv add <pkg>"
  echo "  pip install -g     → uv tool install <pkg>"
  echo "  pip install -r     → uv pip install -r requirements.txt"
  return 1
}

pip3() {
  echo "⚠ Use uv instead of pip3"
  echo "  pip3 install <pkg> → uv add <pkg>"
  return 1
}

alias python="$(uv python find)"
alias python3="$(uv python find)"

ipinfo() {
  if [[ -z "$1" ]]; then
    curl -s "https://ipinfo.io"
  else
    curl -s "https://ipinfo.io/$1"
  fi
}

# bat
export BAT_THEME="TwoDark"
alias cat="bat"

# eza
alias ls="eza --icons"
alias ll="eza --icons -la"
alias lt="eza --icons --tree"

# fd + fzf
export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type d --hidden --follow --exclude .git"

# btop
alias top="btop"

# zoxide (smarter cd)
eval "$(zoxide init zsh)"

# iTerm2 tab title (current directory name)
autoload -Uz add-zsh-hook
_set_iterm_tab_title() {
  echo -ne "\e]1;${PWD##*/}\a"
}
add-zsh-hook precmd _set_iterm_tab_title
add-zsh-hook preexec _set_iterm_tab_title

# Starship (must be last)
eval "$(starship init zsh)"
